# Default is paper mode. Do not put real keys in git.
SUPERAJAN_ENV=local
SUPERAJAN_MODE=paper
SUPERAJAN_LOG_LEVEL=INFO

# Public endpoints used for market data.
POLYMARKET_GAMMA_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_BASE_URL=https://clob.polymarket.com
KALSHI_BASE_URL=https://trading-api.kalshi.com/trade-api/v2
BINANCE_USDS_FUTURES_BASE_URL=https://fapi.binance.com
OKX_BASE_URL=https://www.okx.com
COINBASE_PUBLIC_BASE_URL=https://api.coinbase.com/api/v3/brokerage/market

# Local storage for phase 1.
SQLITE_PATH=data/superajan12.sqlite3
AUDIT_LOG_PATH=data/audit/events.jsonl

# Risk defaults for paper mode.
MAX_MARKET_RISK_USDC=10
MAX_DAILY_LOSS_USDC=25
MIN_VOLUME_USDC=1000
MAX_SPREAD_BPS=1200
MIN_LIQUIDITY_USDC=250
MAX_REFERENCE_PRICE_DEVIATION_BPS=75
